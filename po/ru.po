#: src/Distances/DataAnalysis/Binary/FaithSimilarity.md:5
msgid "$$ \\frac{|X \\cap Y| + |\\overline{X \\Delta Y}|}{2n} $$"
msgstr ""

#: src/Distances/DataAnalysis/Binary/FaithSimilarity.md:9
msgid "The Faith similarity is a similarity on ${0, 1}^n$."
