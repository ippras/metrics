msgstr ""

#: src/Distances/DataAnalysis/Binary/ForbesMozleySimilarity.md:9
msgid "The Forbes–Mozley similarity is a similarity on ${0, 1}^n$."
msgstr ""

#: src/Distances/DataAnalysis/Binary/GowerLegendreSimilarity.md:5
msgid "$$ \\frac{|\\overline{X \\Delta Y}|}{a|X \\Delta Y| + |\\overline{X \\Delta Y}|} = \\frac{|\\overline{X \\Delta Y}|}{n + (a - 1)|X \\Delta Y|} $$"
msgstr ""

#: src/Distances/DataAnalysis/Binary/GowerLegendreSimilarity.md:9
msgid "The Gower–Legendre similarity is a similarity on ${0, 1}^n$."
msgstr ""

